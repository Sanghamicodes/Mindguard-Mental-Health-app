
/*
  # Mental Health - Seed Data and Auth Trigger

  Seeds the symptoms catalog and creates the auto-profile trigger on user signup.
*/

-- Seed symptoms catalog
INSERT INTO symptoms (name, category, description, severity_weight) VALUES
  ('Persistent Sadness', 'emotional', 'Feeling sad or empty most of the day', 1.5),
  ('Hopelessness', 'emotional', 'Feeling hopeless about the future', 1.8),
  ('Irritability', 'emotional', 'Feeling easily annoyed or angry', 1.2),
  ('Anxiety', 'emotional', 'Excessive worry or nervousness', 1.4),
  ('Panic Attacks', 'emotional', 'Sudden intense fear with physical symptoms', 1.9),
  ('Loss of Interest', 'behavioral', 'No longer enjoying previously enjoyed activities', 1.6),
  ('Social Withdrawal', 'behavioral', 'Avoiding friends, family, and social activities', 1.4),
  ('Changes in Appetite', 'behavioral', 'Significant increase or decrease in appetite', 1.1),
  ('Self-Harm Thoughts', 'behavioral', 'Thoughts of hurting oneself', 2.0),
  ('Substance Use', 'behavioral', 'Increased use of alcohol or drugs', 1.7),
  ('Fatigue', 'physical', 'Persistent tiredness and low energy', 1.2),
  ('Headaches', 'physical', 'Frequent or severe headaches', 0.8),
  ('Sleep Problems', 'physical', 'Difficulty sleeping or oversleeping', 1.3),
  ('Concentration Difficulty', 'cognitive', 'Trouble focusing or making decisions', 1.3),
  ('Memory Problems', 'cognitive', 'Forgetting things or poor memory', 1.1),
  ('Racing Thoughts', 'cognitive', 'Uncontrollable fast-paced thinking', 1.4),
  ('Negative Self-Talk', 'cognitive', 'Persistent negative thoughts about self', 1.5)
ON CONFLICT (name) DO NOTHING;

-- Auto-create profile on new user signup
CREATE OR REPLACE FUNCTION handle_new_user()
RETURNS trigger AS $$
BEGIN
  INSERT INTO public.profiles (id, full_name, role)
  VALUES (
    new.id,
    COALESCE(new.raw_user_meta_data->>'full_name', ''),
    COALESCE(new.raw_user_meta_data->>'role', 'patient')
  )
  ON CONFLICT (id) DO NOTHING;
  RETURN new;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION handle_new_user();
